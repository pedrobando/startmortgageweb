# START Mortgage — environment template
# Copy to .env (or .env.local) and fill in. The .env file is gitignored.

# Postgres connection string. Local dev: postgres://USER@localhost:5432/startmortgage_dev
DATABASE_URI=postgres://USER:PASS@HOST:5432/startmortgage
# Some Payload code paths still read DATABASE_URL — keep both in sync.
DATABASE_URL=postgres://USER:PASS@HOST:5432/startmortgage

# 32 bytes hex. JWT/cookie secret. Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=change-me-32-bytes-hex

# 24 bytes hex. Live preview / draft mode token.
PREVIEW_SECRET=change-me-24-bytes-hex

# 24 bytes hex. Auth for POST /api/seed.
SEED_SECRET=change-me-24-bytes-hex

# 24 bytes hex. Auth for cron jobs.
CRON_SECRET=change-me-24-bytes-hex

# Public origin of the site (no trailing slash).
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Production-only — leave blank in local dev to disable.
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@startmortgage.com
RESEND_NOTIFICATION_TO=hello@startmortgage.com
BLOB_READ_WRITE_TOKEN=
